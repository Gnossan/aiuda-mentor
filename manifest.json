{
    "manifest_version": 3,
    "name": "AIuda Mentor",
    "version": "0.3.3",
    "description": "AI-driven research assistant — projects, sources, memory",
    "action": {
        "default_title": "AIuda Mentor",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "permissions": [
        "storage",
        "sidePanel",
        "search",
        "tabs",
        "windows"
    ],
    "host_permissions": [
        "https://aiuda-mentor-backend.vercel.app/*",
        "https://annotated-reader-backend.vercel.app/*"
    ],
    "externally_connectable": {
        "ids": ["*"],
        "matches": [
            "https://aiuda-mentor-backend.vercel.app/*",
            "https://annotated-reader-backend.vercel.app/*"
        ]
    },
    "background": {
        "service_worker": "background.js"
    },
    "side_panel": {
        "default_path": "sidepanel.html"
    }
}
